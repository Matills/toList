{
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended",
      "@vue/typescript/recommended"
    ],
    "rules": {
      "@typescript-eslint/ban-types": [
        "error",
        {
          "types": {
            "{}": false
          },
          "extendDefaults": true
        }
      ],
      "@typescript-eslint/no-explicit-any": "off"
    }
}